{
  "realm": "workshop",
  "enabled": true,
  "clients": [
    {
      "_comment": "Confidential client — server-to-server (client_credentials). Used by the curl test in README-DECK Step 5.3.",
      "clientId": "mcp-service-client",
      "name": "MCP Service Client (confidential)",
      "enabled": true,
      "publicClient": false,
      "secret": "mcp-service-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": ["mcp-tools"],
      "protocol": "openid-connect"
    },
    {
      "_comment": "Public client — desktop/CLI apps (auth code + PKCE, no secret). Used by VS Code / Claude Desktop / the by-hand PKCE flow in Step 5.4.",
      "clientId": "mcp-pkce-client",
      "name": "MCP PKCE Client (public)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:8000/mcp-oauth/callback",
        "http://localhost:8000/*",
        "http://127.0.0.1:*/callback",
        "vscode://*",
        "claude://*"
      ],
      "webOrigins": ["http://localhost:8000"],
      "defaultClientScopes": ["openid", "profile", "mcp-tools"],
      "protocol": "openid-connect"
    }
  ],
  "clientScopes": [
    {
      "name": "mcp-tools",
      "description": "MCP tool access scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    }
  ],
  "users": [
    {
      "username": "agent-user",
      "enabled": true,
      "email": "agent@bootcamp.local",
      "firstName": "Agent",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "agent123",
          "temporary": false
        }
      ]
    }
  ]
}
