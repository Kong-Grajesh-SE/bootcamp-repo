{
  "realm": "workshop",
  "enabled": true,
  "clients": [
    {
      "clientId": "mcp-oauth-client",
      "name": "MCP OAuth Client",
      "enabled": true,
      "publicClient": true,
      "secret": "mcp-oauth-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8000/mcp-oauth/callback",
        "http://localhost:8000/*"
      ],
      "webOrigins": ["http://localhost:8000"],
      "defaultClientScopes": ["openid", "profile", "mcp-tools"],
      "protocol": "openid-connect"
    }
  ],
  "clientScopes": [
    {
      "name": "mcp-tools",
      "description": "MCP tool access scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    }
  ],
  "users": [
    {
      "username": "agent-user",
      "enabled": true,
      "email": "agent@bootcamp.local",
      "firstName": "Agent",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "agent123",
          "temporary": false
        }
      ]
    }
  ]
}
